NodeKeeper="*uid://dfapl3sic804d"
ArtService="*uid://dews4o601kwaa"
ArtDispatcher="*uid://bqt0p0g14m76i"
DiscordRp="*uid://0q8y2848qla1"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="PlayStar"

